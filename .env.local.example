# ─── Sanity CMS ─────────────────────────────────────────────────────────────
# Get these from https://sanity.io/manage → your project → Settings → API

# Project ID (public — safe to expose in browser)
NEXT_PUBLIC_SANITY_PROJECT_ID=

# Dataset name (usually "production")
NEXT_PUBLIC_SANITY_DATASET=production

# API token — used by the migration script and webhook revalidation
# Minimum permissions required: "Editor" for migration, "Viewer" is enough for read-only
# NEVER commit this to git. Generate at: sanity.io/manage → API → Tokens
SANITY_API_TOKEN=

# Webhook secret — used to authenticate Sanity webhook calls to /api/revalidate
# Set this to any random string (e.g. run: openssl rand -hex 32)
# Must match the secret you set in Sanity Studio → Settings → Webhooks → HTTP Headers
SANITY_WEBHOOK_SECRET=
